# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ---------- Supabase ----------
# Project Settings → API in your Supabase dashboard.

# Public project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public "anon" key — safe to expose to the browser; RLS policies (see
# supabase/migrations) are what actually restrict what it can access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, bypasses RLS entirely. Used by every
# module under src/lib/server/ for data access, and by the Admin API
# (auth.admin.createUser/deleteUser) when User Administration provisions a
# new login. Never expose this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Gemini (document extraction) ----------
# Server-only. Get a key at https://aistudio.google.com/apikey.
# Powers src/lib/gemini/extract.ts — structured invoice-field extraction
# from uploaded PDFs/images at Capture time.
GEMINI_API_KEY=

# ---------- DocuWare / SAP export (Make.com) ----------
# Server-only. Webhook URL for the "Store to DocuWare" Make.com scenario —
# posts the captured invoice file + index fields, which DocuWare then
# stores and runs its own XML-export automation against. See
# src/lib/server/docuware.ts. If unset, capture still succeeds; the
# invoice's xml_status is just marked 'Failed' instead of 'Pending'.
DOCUWARE_STORE_WEBHOOK_URL=
